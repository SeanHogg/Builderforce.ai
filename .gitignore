# Builderforce.ai root .gitignore

# Node
node_modules/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Build outputs
frontend/.next/
frontend/out/
.vercel/
worker/.next/
worker/dist/
# sdk/dist and studio/dist are committed (like studio-embedded/brain-embedded/
# builderforce-embedded) so the CF Pages frozen install can resolve the linked
# `@seanhogg/builderforce-sdk` + `@seanhogg/builderforce-studio` packages — their
# `link:` targets have no build step in CI. Rebuild via `npm run build` in each.

# Env
.env
.env.*
frontend/.env.local
worker/.env

# IDE
.vscode/
.idea/

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage
coverage/

# Test
frontend/test-output/
worker/test-output/

# Ignore local secrets
worker/secrets.json
# Cloudflare Workers local secrets (NEON_DATABASE_URL etc.) — never commit
.dev.vars
**/.dev.vars
# Wrangler build/deploy artifacts — never commit
**/.wrangler/
# Operator-only security findings / leak disclosures — never commit
*.local.md

# Runtime workspace/session data (transient)
.builderforce/sessions/
agent-runtime/.builderforce/sessions/

# npm lockfiles in pnpm-resolved packages.
#
# Every deployed/published package resolves from its own pnpm-lock.yaml, which
# is what ci.yml gates with --frozen-lockfile. A package-lock.json alongside it
# is never read but IS regenerated by a stray local `npm install`, and it used
# to be what release.yml/publish-vscode.yml actually shipped from — so the
# artifact in production could carry versions no gate had type-checked.
# docs-site and webdit are genuinely npm-resolved (no pnpm-lock.yaml) and keep
# theirs.
package-lock.json
!docs-site/package-lock.json
!webdit/package-lock.json
