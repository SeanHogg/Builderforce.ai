{
  "$schema": "http://json-schema.org/draft-2020-12/schema",
  "$id": "https://builderforce.ai/schemas/basis-payload-v1.schema.json",
  "title": "Basis Payload v1.0.0",
  "description": "Canonical JSON schema for structured basis data: identity, claims, evidence, reasoning chain, uncertainty, context, and extensions.",
  "type": "object",
  "required": ["schema_version", "basis_id", "agent_id", "claims", "evidence"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the payload schema"
    },
    "basis_id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique identifier for this basis instance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent_id": {
      "type": "string",
      "description": "Identifier of the agent that produced this basis"
    },
    "session_id": {
      "type": ["string", "null"],
      "description": "Identifier of the agent session; optional"
    },
    "parent_basis_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "UUID of a parent basis if this is a refinement/rebuttal"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Claim"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/definitions/Evidence"
      }
    },
    "reasoning_chain": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReasoningStep"
      }
    },
    "uncertainty": {
      "$ref": "#/definitions/Uncertainty"
    },
    "context": {
      "$ref": "#/definitions/Context"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9]*(-[a-z0-9]+)*$": {
          "type": "object",
          "description": "Extension namespace with reverse-DNS style keys"
        }
      },
      "description": "Optional extension fields; consumers ignore unknown extension namespaces"
    }
  },
  "definitions": {
    "Claim": {
      "type": "object",
      "required": ["claim_id", "text", "confidence"],
      "properties": {
        "claim_id": {
          "type": "string",
          "format": "uuid"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable assertion"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Confidence score in [0, 1]"
        },
        "confidence_method": {
          "type": ["string", "null"],
          "enum": ["bayesian", "heuristic", "llm-self-report", "empirical"],
          "description": "Method used to compute confidence"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional classification tags"
        },
        "status": {
          "type": "string",
          "default": "asserted",
          "enum": ["asserted", "retracted", "superseded"]
        }
      }
    },
    "Evidence": {
      "type": "object",
      "required": ["evidence_id", "claim_ids", "type", "weight"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this evidence item"
        },
        "claim_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "format": "uuid"
          },
          "description": "Claim IDs this evidence supports"
        },
        "type": {
          "type": "string",
          "enum": ["document", "database_record", "api_response", "agent_output", "human_input", "computed"],
          "description": "Kind of evidence source"
        },
        "uri": {
          "type": ["string", "null"],
          "description": "URI to retrieve the full evidence"
        },
        "title": {
          "type": ["string", "null"],
          "description": "Title or name of the evidence source"
        },
        "excerpt": {
          "type": ["string", "null"],
          "description": "Excerpt or snippet for searchability"
        },
        "retrieved_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When this evidence was retrieved"
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Strength of support for linked claims [0, 1]"
        },
        "provenance": {
          "type": "object",
          "required": ["source_system"],
          "properties": {
            "source_system": {
              "type": "string",
              "description": "System that generated this evidence"
            },
            "source_version": {
              "type": ["string", "null"],
              "description": "Version of the source system"
            },
            "checksum": {
              "type": ["string", "null"],
              "pattern": "^[0-9a-fA-F]{64}$",
              "description": "SHA-256 checksum of evidence content (optional but recommended)"
            }
          }
        }
      }
    },
    "ReasoningStep": {
      "type": "object",
      "required": ["step", "description", "evidence_ids", "claim_ids", "inference_type"],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1,
          "description": "Sequential step number"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "claim_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "inference_type": {
          "type": "string",
          "enum": ["deductive", "inductive", "abductive", "analogical", "lookup"],
          "description": "Type of inference made at this step"
        }
      }
    },
    "Uncertainty": {
      "type": "object",
      "required": ["overall_confidence", "known_unknowns", "assumptions", "contradictions"],
      "properties": {
        "overall_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Overall confidence in the basis [0, 1]"
        },
        "known_unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Known limitations or unknowns"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Assumptions made in deriving the basis"
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id_a", "claim_id_b"],
            "properties": {
              "claim_id_a": {
                "type": "string",
                "format": "uuid"
              },
              "claim_id_b": {
                "type": "string",
                "format": "uuid"
              },
              "description": {
                "type": "string"
              }
            }
          },
          "description": "Pairs of claims with contradictory statements"
        }
      }
    },
    "Context": {
      "type": "object",
      "required": ["model_id"],
      "properties": {
        "task_id": {
          "type": ["string", "null"],
          "description": "ID of the task this basis addresses"
        },
        "task_description": {
          "type": ["string", "null"],
          "description": "Description of the task"
        },
        "model_id": {
          "type": "string",
          "description": "Model or system that produced this basis"
        },
        "model_version": {
          "type": ["string", "null"],
          "description": "Version of the model"
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool_name", "called_at"],
            "properties": {
              "tool_name": {
                "type": "string",
                "description": "Name of the tool used"
              },
              "input_summary": {
                "type": "string",
                "description": "Summary of tool input"
              },
              "output_summary": {
                "type": "string",
                "description": "Summary of tool output"
              },
              "called_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "environment": {
          "type": "string",
          "enum": ["production", "staging", "development", "test"],
          "description": "Deployment environment"
        }
      }
    }
  }
}