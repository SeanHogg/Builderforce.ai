{
  "name": "@seanhogg/builderforce-brain-embedded",
  "version": "2026.7.48",
  "description": "Embeddable AI assistant ('Brain') for React — headless streaming chat core with an MCP-style action registry. Drop a BrainProvider into any React app, register tools the assistant can call, and stream tool-capable chat completions through the Builderforce gateway. Auth, persistence, and system prompts are injected, so the same core powers builderforce.ai and external embeds.",
  "license": "MIT",
  "author": "Sean Hogg",
  "homepage": "https://github.com/SeanHogg/Builderforce.ai/tree/main/brain-embedded#readme",
  "bugs": {
    "url": "https://github.com/SeanHogg/Builderforce.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanHogg/Builderforce.ai.git",
    "directory": "brain-embedded"
  },
  "keywords": [
    "builderforce",
    "ai-assistant",
    "chat",
    "streaming",
    "tool-calling",
    "mcp",
    "react",
    "embeddable",
    "sdk"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./chatError": {
      "types": "./dist/chatError.d.ts",
      "import": "./dist/chatError.mjs",
      "require": "./dist/chatError.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck:native": "tsgo --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260627.2",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.3",
    "@builderforce/agent-stall": "link:../packages/agent-stall"
  }
}
