# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hiredvideo

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=30d
REFRESH_TOKEN_EXPIRY=30d

# AWS S3 (Video Storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=hired-video-uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Email (Notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@hired.video

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/callback/linkedin

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Redis (Queue)
REDIS_URL=redis://localhost:6379

# Node threshold (for video processing time)
NODE_THRESHOLD=300