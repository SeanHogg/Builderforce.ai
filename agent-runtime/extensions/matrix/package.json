{
  "name": "@builderforce/matrix",
  "version": "2026.3.21",
  "description": "BuilderForceAgents Matrix channel plugin",
  "type": "module",
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-nodejs": "^0.6.1",
    "@vector-im/matrix-bot-sdk": "0.8.0-element.3",
    "markdown-it": "14.3.0",
    "music-metadata": "^11.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@seanhogg/builderforce-agents": "workspace:*"
  },
  "builderforce": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "matrix",
      "label": "Matrix",
      "selectionLabel": "Matrix (plugin)",
      "docsPath": "/channels/matrix",
      "docsLabel": "matrix",
      "blurb": "open protocol; install the plugin to enable.",
      "order": 70,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@builderforce/matrix",
      "localPath": "extensions/matrix",
      "defaultChoice": "npm"
    }
  }
}
