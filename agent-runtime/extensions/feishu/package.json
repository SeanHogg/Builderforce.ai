{
  "name": "@builderforce/feishu",
  "version": "2026.3.21",
  "description": "BuilderForceAgents Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.71.1",
    "@sinclair/typebox": "0.34.52",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@seanhogg/builderforce-agents": "workspace:*"
  },
  "builderforce": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@builderforce/feishu",
      "localPath": "extensions/feishu",
      "defaultChoice": "npm"
    }
  }
}
