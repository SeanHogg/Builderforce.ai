{
  "name": "builderforce-frontend",
  "version": "2026.7.104",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';if(fs.existsSync(p)){fs.rmSync(p,{recursive:true});console.log('Removed .next');}else{console.log('.next not found');}\"",
    "dev": "next dev",
    "build": "next build",
    "cf-build": "npm run build && npx @cloudflare/next-on-pages && echo '_worker.js' > .vercel/output/static/.assetsignore && node scripts/strip-worker-assets.js && node scripts/stamp-sw-version.js && sed -i 's/\\br\\.fetch\\b/(r||self).fetch/g' .vercel/output/static/_worker.js/index.js",
    "cf-deploy": "npm run cf-build && npx wrangler deploy --no-bundle",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:native": "tsgo --noEmit"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@huggingface/transformers": "^3.8.1",
    "@isomorphic-git/lightning-fs": "^4.6.3",
    "@monaco-editor/react": "^4.6.0",
    "@seanhogg/builderforce-brain-embedded": "link:../brain-embedded",
    "@seanhogg/builderforce-brain-ui": "link:../packages/brain-ui",
    "@seanhogg/builderforce-embedded": "link:../builderforce-embedded",
    "@seanhogg/builderforce-memory": "^2026.7.12",
    "@seanhogg/builderforce-memory-engine": "^2026.7.12",
    "@seanhogg/builderforce-quality": "^2026.7.5",
    "@seanhogg/builderforce-sdk": "link:../sdk",
    "@seanhogg/builderforce-studio": "link:../studio",
    "@seanhogg/builderforce-studio-embedded": "link:../studio-embedded",
    "@seanhogg/builderforce-voice": "link:../voice",
    "@webcontainer/api": "^1.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.3.0",
    "@xyflow/react": "^12.11.2",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "isomorphic-git": "^1.40.0",
    "lib0": "^0.2.94",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.56.0",
    "mp4-muxer": "^5.2.2",
    "next": "15.5.2",
    "next-intl": "^4.13.4",
    "onnxruntime-web": "^1.21.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.27.0",
    "y-monaco": "^0.1.4",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.3",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "jsdom": "^28.1.0",
    "postcss": "^8",
