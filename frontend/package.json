    "vitest": "^4.0.18",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "overrides": {
      "d3-array": "^3.2.4",
      "d3-shape": "^3.2.0",
      "d3-path": "^3.1.0",
      "sharp": "0.35.3"
    }
  }
}
