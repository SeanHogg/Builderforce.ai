{
  "name": "builderforce-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf-build": "npm run build && npx @cloudflare/next-on-pages && echo '_worker.js' > .vercel/output/static/.assetsignore && sed -i 's/\\br\\.fetch\\b/(r||self).fetch/g' .vercel/output/static/_worker.js/index.js",
    "cf-deploy": "npm run cf-build && npx wrangler deploy --no-bundle",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@huggingface/transformers": "^3.8.1",
    "@monaco-editor/react": "^4.6.0",
    "@webcontainer/api": "^1.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.3.0",
    "lib0": "^0.2.94",
    "monaco-editor": "^0.55.1",
    "next": "15.5.2",
    "react": "^18",
    "react-dom": "^18",
    "y-monaco": "^0.1.4",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.3",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.0.1",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}