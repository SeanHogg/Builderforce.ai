NEXT_PUBLIC_WORKER_URL=http://localhost:8787
NEXT_PUBLIC_AUTH_API_URL=https://api.builderforce.ai
# Base URL for SEO (og:image, canonical). Set in production to e.g. https://builderforce.ai
NEXT_PUBLIC_APP_URL=https://builderforce.ai
# Public bfq_ ingest key for dogfooding the Product Quality error collector. Read
# server-side in the root layout and passed to the browser client (no NEXT_PUBLIC_
# needed — it's a public source key). Mint one under Quality → Sources.
NEXT_BUILDERFORCE_ERROR_API_KEY=bfq_xxx
