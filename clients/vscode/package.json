{
  "name": "builderforce-ai",
  "displayName": "BuilderForce.ai",
  "description": "BuilderForce AI coding agent — chat with a codebase-aware agent in your VS Code sidebar.",
  "version": "2026.6.31",
  "publisher": "builderforce",
  "license": "MIT",
  "author": "Sean Hogg",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "agent",
    "chat",
    "coding assistant",
    "builderforce",
    "copilot"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  },
  "homepage": "https://builderforce.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanHogg/Builderforce.ai.git",
    "directory": "clients/vscode"
  },
  "bugs": {
    "url": "https://github.com/SeanHogg/Builderforce.ai/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "builderforce",
          "title": "BuilderForce",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "builderforce": [
        {
          "id": "builderforce.sessions",
          "name": "Sessions"
        },
        {
          "id": "builderforce.project",
          "name": "Project & Tasks"
        },
        {
          "id": "builderforce.insights",
          "name": "Insights"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "builderforce.sessions",
        "contents": "Start a conversation with the BuilderForce agent.\n[New Session](command:builderforce.newSession)\n\nThe chat opens as a document in the editor so you can review changes side by side."
      },
      {
        "view": "builderforce.insights",
        "contents": "Sign in to see live builder-level insights (token spend, budget, top model, cost per merged PR).\n[Sign In](command:builderforce.signIn)"
      }
    ],
    "commands": [
      {
        "command": "builderforce.openChat",
        "title": "BuilderForce: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "builderforce.refreshInsights",
        "title": "BuilderForce: Refresh Insights",
        "icon": "$(sync)"
      },
      {
        "command": "builderforce.signIn",
        "title": "BuilderForce: Sign In",
        "icon": "$(sign-in)"
      },
      {
        "command": "builderforce.signOut",
        "title": "BuilderForce: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "builderforce.newSession",
        "title": "BuilderForce: New Session",
        "icon": "$(add)"
      },
      {
        "command": "builderforce.openSession",
        "title": "BuilderForce: Open Session"
      },
      {
        "command": "builderforce.renameSession",
        "title": "BuilderForce: Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "builderforce.deleteSession",
        "title": "BuilderForce: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "builderforce.selectProject",
        "title": "BuilderForce: Select Project",
        "icon": "$(folder)"
      },
      {
        "command": "builderforce.createProject",
        "title": "BuilderForce: New Project",
        "icon": "$(new-folder)"
      },
      {
        "command": "builderforce.createWorkspace",
        "title": "BuilderForce: Create / Switch Workspace",
        "icon": "$(organization)"
      },
      {
        "command": "builderforce.refreshProjects",
        "title": "BuilderForce: Refresh Tasks",
        "icon": "$(sync)"
      },
      {
        "command": "builderforce.hideDoneTasks",
        "title": "BuilderForce: Hide Done Tasks",
        "icon": "$(eye)"
      },
      {
        "command": "builderforce.showDoneTasks",
        "title": "BuilderForce: Show Done Tasks",
        "icon": "$(eye-closed)"
      },
      {
        "command": "builderforce.startTaskSession",
        "title": "BuilderForce: Start Session on Task",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "builderforce.setTaskStatus",
        "title": "BuilderForce: Set Task Status",
        "icon": "$(checklist)"
      },
      {
        "command": "builderforce.runTask",
        "title": "BuilderForce: Run Task on Platform",
        "icon": "$(play)"
      },
      {
        "command": "builderforce.humanRequests",
        "title": "BuilderForce: Review Approvals",
        "icon": "$(verified)"
      },
      {
        "command": "builderforce.openBoard",
        "title": "BuilderForce: Open Board",
        "icon": "$(layout)"
      },
      {
        "command": "builderforce.openView",
        "title": "BuilderForce: Open Page…",
        "icon": "$(browser)"
      },
      {
        "command": "builderforce.diagnose",
        "title": "BuilderForce: Diagnose Connection",
        "icon": "$(pulse)"
      },
      {
        "command": "builderforce.rescanCodebase",
        "title": "BuilderForce: Rescan Codebase",
        "icon": "$(sync)"
      },
      {
        "command": "builderforce.pickModel",
        "title": "BuilderForce: Pick Model",
        "icon": "$(list-selection)"
      },
      {
        "command": "builderforce.openSettings",
        "title": "BuilderForce: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "builderforce.editorChat",
        "title": "BuilderForce: Chat",
        "icon": {
          "light": "media/icon.png",
          "dark": "media/icon.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "builderforce.editorChat",
          "group": "navigation@-1"
        }
      ],
      "view/title": [
        {
          "command": "builderforce.refreshInsights",
          "when": "view == builderforce.insights",
          "group": "navigation@1"
        },
        {
          "command": "builderforce.newSession",
          "when": "view == builderforce.sessions",
          "group": "navigation@1"
        },
        {
          "command": "builderforce.rescanCodebase",
          "when": "view == builderforce.sessions",
          "group": "navigation@2"
        },
        {
          "command": "builderforce.pickModel",
          "when": "view == builderforce.sessions",
          "group": "overflow@1"
        },
        {
          "command": "builderforce.signIn",
          "when": "view == builderforce.sessions",
          "group": "overflow@2"
        },
        {
          "command": "builderforce.signOut",
          "when": "view == builderforce.sessions",
          "group": "overflow@3"
        },
        {
          "command": "builderforce.openSettings",
          "when": "view == builderforce.sessions",
          "group": "overflow@4"
        },
        {
          "command": "builderforce.createProject",
          "when": "view == builderforce.project",
          "group": "navigation@0"
        },
        {
          "command": "builderforce.selectProject",
          "when": "view == builderforce.project",
          "group": "navigation@1"
        },
        {
          "command": "builderforce.createWorkspace",
          "when": "view == builderforce.project",
          "group": "1_workspace@1"
        },
        {
          "command": "builderforce.openBoard",
          "when": "view == builderforce.project",
          "group": "navigation@2"
        },
        {
          "command": "builderforce.openView",
          "when": "view == builderforce.project",
          "group": "navigation@3"
        },
        {
          "command": "builderforce.humanRequests",
          "when": "view == builderforce.project",
          "group": "navigation@4"
        },
        {
          "command": "builderforce.refreshProjects",
          "when": "view == builderforce.project",
          "group": "navigation@5"
        },
        {
          "command": "builderforce.hideDoneTasks",
          "when": "view == builderforce.project && !builderforce.hideDoneTasks",
          "group": "navigation@6"
        },
        {
          "command": "builderforce.showDoneTasks",
          "when": "view == builderforce.project && builderforce.hideDoneTasks",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "builderforce.renameSession",
          "when": "view == builderforce.sessions && viewItem == builderforceSession",
          "group": "inline@1"
        },
        {
          "command": "builderforce.deleteSession",
          "when": "view == builderforce.sessions && viewItem == builderforceSession",
          "group": "inline@2"
        },
        {
          "command": "builderforce.runTask",
          "when": "view == builderforce.project && viewItem == builderforceTask",
          "group": "inline@1"
        },
        {
          "command": "builderforce.startTaskSession",
          "when": "view == builderforce.project && viewItem == builderforceTask",
          "group": "inline@2"
        },
        {
          "command": "builderforce.setTaskStatus",
          "when": "view == builderforce.project && viewItem == builderforceTask",
          "group": "inline@3"
        }
      ],
      "commandPalette": [
        {
          "command": "builderforce.openSession",
          "when": "false"
        },
        {
          "command": "builderforce.deleteSession",
          "when": "false"
        },
        {
          "command": "builderforce.renameSession",
          "when": "false"
        },
        {
          "command": "builderforce.startTaskSession",
          "when": "false"
        },
        {
          "command": "builderforce.setTaskStatus",
          "when": "false"
        },
        {
          "command": "builderforce.runTask",
          "when": "false"
        },
        {
          "command": "builderforce.editorChat",
          "when": "false"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "builderforce.agent",
        "name": "builderforce",
        "fullName": "BuilderForce",
        "description": "Codebase-aware BuilderForce coding agent",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "BuilderForce",
      "properties": {
        "builderforce.baseUrl": {
          "type": "string",
          "default": "https://api.builderforce.ai",
          "markdownDescription": "Base URL of the BuilderForce gateway. The OpenAI-compatible endpoint `/llm/v1/chat/completions` is appended automatically. Override for self-hosted deployments."
        },
        "builderforce.webUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Base URL of the BuilderForce web app (where embedded pages like the board live). Leave empty to derive it from `builderforce.baseUrl` (api.* → root domain)."
        },
        "builderforce.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default model id to use. Leave empty to let the gateway pick from the curated coding pool."
        },
        "builderforce.permissionMode": {
          "type": "string",
          "enum": [
            "ask",
            "acceptEdits"
          ],
          "default": "ask",
          "markdownEnumDescriptions": [
            "Ask before applying each file edit or command (recommended).",
            "Apply file edits automatically without prompting."
          ],
          "description": "How the agent applies changes to your workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production && tsc -p ./",
    "compile": "node esbuild.mjs && tsc -p ./",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p ./",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish",
    "typecheck:native": "tsgo --noEmit"
  },
  "dependencies": {
    "@seanhogg/builderforce-memory": "^2026.6.35",
    "@seanhogg/builderforce-memory-engine": "^2026.6.35"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.0",
    "typescript": "^6.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  }
}
