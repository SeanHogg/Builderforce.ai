{
  "name": "builderforce-api",
  "version": "2026.03.22",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "db:migrate": "node scripts/migrate.mjs",
    "deploy": "node scripts/migrate.mjs && npm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "secrets:from-env": "node scripts/set-secrets-from-env.mjs",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
