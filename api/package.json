{
  "name": "builderforce-api",
  "version": "2026.7.64",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "db:migrate": "node scripts/migrate.mjs",
    "deploy": "node scripts/migrate.mjs && npm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "secrets:from-env": "node scripts/set-secrets-from-env.mjs",
    "db:generate": "npx drizzle-kit@0.30.6 generate",
    "db:push": "npx drizzle-kit@0.30.6 push",
    "type-check": "tsc --noEmit",
    "check:schema": "node scripts/check-schema-drift.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "check:tracks": "node scripts/check-track-manifest.mjs --check",
    "test": "npm run check:schema && npm run check:migrations && npm run check:tracks && vitest run",
    "typecheck:native": "tsgo --noEmit"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@neondatabase/serverless": "^0.10.4",
    "@seanhogg/builderforce-memory": "^2026.6.39",
    "@seanhogg/builderforce-quality": "^2026.7.5",
    "@seanhogg/hired-video-sdk": "^0.3.0",
    "@seanhogg/builderforce-memory-engine": "^2026.6.39",
    "drizzle-orm": "^0.36.4",
    "fflate": "^0.8.2",
    "hono": "^4.6.17",
    "pptxgenjs": "^3.12.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@typescript/native-preview": "7.0.0-dev.20260627.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
