{
  "name": "builderforce-api",
  "version": "2026.05.22",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "db:migrate": "node scripts/migrate.mjs",
    "deploy": "node scripts/migrate.mjs && npm run deploy:worker",
    "deploy:worker": "wrangler deploy",
    "secrets:from-env": "node scripts/set-secrets-from-env.mjs",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "type-check": "tsc --noEmit",
    "check:schema": "node scripts/check-schema-drift.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "test": "npm run check:schema && npm run check:migrations && vitest run"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.17",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
