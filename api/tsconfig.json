{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@builderforce/agent-tools": ["../packages/agent-tools/src/index.ts"],
      "@builderforce/agent-tools/*": ["../packages/agent-tools/src/*"],
      "@builderforce/agent-stall": ["../packages/agent-stall/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
