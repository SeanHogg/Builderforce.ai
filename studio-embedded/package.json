{
  "name": "@seanhogg/builderforce-studio-embedded",
  "version": "0.1.0",
  "description": "Full embeddable AI Video Studio for React — <StudioPanel> drop-in that runs LCM / SD-Turbo diffusion on WebGPU/WebNN, conditioned on a Mamba SSM state for temporal coherence, and muxes MP4 via WebCodecs. React layer on top of the headless @seanhogg/builderforce-studio engine.",
  "license": "MIT",
  "author": "Sean Hogg",
  "homepage": "https://github.com/SeanHogg/Builderforce.ai/tree/main/studio-embedded#readme",
  "bugs": {
    "url": "https://github.com/SeanHogg/Builderforce.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanHogg/Builderforce.ai.git",
    "directory": "studio-embedded"
  },
  "keywords": [
    "builderforce",
    "video-generation",
    "stable-diffusion",
    "lcm",
    "sd-turbo",
    "webgpu",
    "webnn",
    "react",
    "embeddable",
    "studio",
    "in-browser"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@seanhogg/builderforce-studio": ">=0.2.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@seanhogg/builderforce-studio": "file:../studio",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@webgpu/types": "^0.1.50",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
