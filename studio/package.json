{
  "name": "@seanhogg/builderforce-studio",
  "version": "2026.7.20",
  "description": "Headless client-side AI video-generation engine for the browser. Runs LCM / SD-Turbo diffusion on WebGPU or WebNN (onnxruntime-web), CLIP tokenization via @huggingface/transformers, Mamba SSM temporal coherence, and WebCodecs MP4 muxing. No React. For a ready-made <StudioPanel>, see @seanhogg/builderforce-studio-embedded.",
  "license": "MIT",
  "author": "Sean Hogg",
  "homepage": "https://github.com/SeanHogg/Builderforce.ai/tree/main/studio#readme",
  "bugs": {
    "url": "https://github.com/SeanHogg/Builderforce.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanHogg/Builderforce.ai.git",
    "directory": "studio"
  },
  "keywords": [
    "builderforce",
    "video-generation",
    "stable-diffusion",
    "lcm",
    "sd-turbo",
    "webgpu",
    "webnn",
    "onnxruntime-web",
    "mamba",
    "ssm",
    "in-browser",
    "engine",
    "headless"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck:native": "tsgo --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@huggingface/transformers": ">=3.8.0",
    "@seanhogg/builderforce-sdk": ">=0.8.0",
    "onnxruntime-web": ">=1.21.0"
  },
  "dependencies": {
    "mp4-muxer": "^5.2.2"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@seanhogg/builderforce-sdk": "^0.8.1",
    "@types/node": "^24.7.2",
    "@webgpu/types": "^0.1.50",
    "onnxruntime-web": "^1.21.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.35.3"
    }
  }
}
