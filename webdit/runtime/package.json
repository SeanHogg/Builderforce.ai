{
  "name": "@webdit/runtime",
  "version": "0.0.1",
  "private": true,
  "description": "Browser-side runtime for WebDiT bundles. Adds .video.generate() to a WebLLM MLCEngine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:native": "tsgo --noEmit"
  },
  "peerDependencies": {
    "@mlc-ai/web-llm": "^0.2.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@webdit/shared": "*",
    "@webdit/torch": "*",
    "onnxruntime-web": "^1.18.0"
  },
  "devDependencies": {
    "@mlc-ai/web-llm": "^0.2.0",
    "@webdit/convert": "*",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  }
}
