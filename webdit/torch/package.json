{
  "name": "@webdit/torch",
  "version": "0.0.1",
  "private": true,
  "description": "PyTorch-style tensor library in TypeScript. Strided tensors, broadcasting, matmul, activations, NN modules. Pure JS, no native deps. CPU backend only (V0).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./nn": "./src/nn/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:native": "tsgo --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.2.6",
    "@typescript/native-preview": "7.0.0-dev.20260627.2"
  }
}
