# syntax=docker/dockerfile:1.7
#
# Builderforce.ai API worker — `wrangler dev` container.
#
# Cloudflare Workers can run locally via wrangler dev's workerd binary. The
# Worker binds R2 + Durable Objects in production; locally wrangler dev
# provides in-memory replacements automatically (controlled by wrangler.toml).
#
# Environment expected at runtime:
#   - NEON_DATABASE_URL   (real Neon postgres or compatible)
#   - JWT_SECRET
#   - OPENROUTER_API_KEY  (for LLM gateway prompt expansion)
# Inject via docker-compose env_file or env: block.

FROM node:20-bookworm-slim AS deps
WORKDIR /repo/api
COPY api/package.json api/package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm \
    npm install --no-audit --no-fund

FROM deps AS dev
WORKDIR /repo/api
COPY api/ ./
ENV NODE_ENV=development
EXPOSE 8787
# `wrangler dev --ip 0.0.0.0` so the dev server is reachable from other
# containers (frontend) and from the host.
CMD ["npx", "wrangler", "dev", "--ip", "0.0.0.0", "--port", "8787"]
