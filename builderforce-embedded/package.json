{
  "name": "@seanhogg/builderforce-embedded",
  "version": "0.1.0",
  "description": "Embed BuilderForce surfaces (Product Management, Agile, Governance) into any React host with one component. <BuilderForceEmbed view=\"kanban\" token={sso} /> mounts a sandboxed iframe, hands the SSO/tenant JWT to it over postMessage (never in the URL), auto-resizes to content, and syncs deep links. The single DRY embed rail for re-embedding BuilderForce back into BurnRateOS and other host apps.",
  "license": "MIT",
  "author": "Sean Hogg",
  "homepage": "https://github.com/SeanHogg/Builderforce.ai/tree/main/builderforce-embedded#readme",
  "bugs": {
    "url": "https://github.com/SeanHogg/Builderforce.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanHogg/Builderforce.ai.git",
    "directory": "builderforce-embedded"
  },
  "keywords": [
    "builderforce",
    "embed",
    "iframe",
    "react",
    "sso",
    "multi-tenant",
    "product-management",
    "agile",
    "governance",
    "embeddable"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
